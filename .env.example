JWT_SIGNING_METHOD=HS256

# HMAC (HS256/HS384/HS512): set JWT_SECRET_KEY to a random string, leave JWT_PUBLIC_KEY empty
# Asymmetric (RS*/PS*/ES*/EdDSA): set JWT_SECRET_KEY to PEM private key, JWT_PUBLIC_KEY to PEM public key
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_PUBLIC_KEY=
JWT_ACCESS_TOKEN_TTL=30
JWT_REFRESH_TOKEN_TTL=10080
JWT_REDIS_HOST=localhost
JWT_REDIS_PORT=6379
JWT_REDIS_PASSWORD=
JWT_REDIS_DB=0
JWT_BLACKLIST_INCIDENT_TIME_KEY=gofortify:incident
JWT_BLACKLIST_DRIVER=redis